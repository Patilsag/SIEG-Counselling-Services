# Copy this file to ".env" and fill in the values. Never commit the real .env.

# --- Lead capture (Google Sheet) ---
# The Web app URL from your Google Sheet's Apps Script deployment.
GOOGLE_SHEETS_WEBHOOK_URL=
# A long random string. Must EXACTLY match SHARED_SECRET in the Apps Script.
LEAD_WEBHOOK_TOKEN=

# --- Automatic email delivery (Resend) ---
# API key from https://resend.com (free 3k/mo). Leave blank to disable email entirely.
RESEND_API_KEY=
# Verified sender — must be on a domain you verified in Resend.
LEAD_EMAIL_FROM=Sieg Counselling Services <info@siegcounselling.com>
# Where new-lead alerts are sent (usually your own inbox).
LEAD_NOTIFY_EMAIL=info@siegcounselling.com
# Absolute base URL used for the guide links inside emails.
SITE_URL=https://www.siegcounselling.com
